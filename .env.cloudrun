# Minimal environment variables for Cloud Run deployment
# The server will start even without these, but with limited functionality

# Server Configuration (automatically set by Cloud Run)
NODE_ENV=production
PORT=8080

# Database (OPTIONAL - server will run without these)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fifa-wc?retryWrites=true&w=majority
# REDIS_URL=redis://default:password@your-redis-host:6379

# AI Configuration (REQUIRED for AI features)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# DEFAULT_MODEL=gpt-4-turbo-preview
# MAX_TOKENS=1000
# TEMPERATURE=0.7

# Authentication (REQUIRED for auth features)
# JWT_SECRET=your-secure-random-string-min-32-characters
# JWT_EXPIRE=7d

# CORS (OPTIONAL)
# CLIENT_URL=https://your-frontend-domain.com
# ALLOWED_ORIGINS=https://your-frontend-domain.com
